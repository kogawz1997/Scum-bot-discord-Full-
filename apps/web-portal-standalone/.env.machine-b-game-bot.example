# Machine B: execution node
# The player portal should not run here. This file only exists because the
# profile generator materializes both root and portal env files together.

NODE_ENV=production
WEB_PORTAL_MODE=player
WEB_PORTAL_HOST=127.0.0.1
WEB_PORTAL_PORT=3300
WEB_PORTAL_BASE_URL=http://127.0.0.1:3300
WEB_PORTAL_LEGACY_ADMIN_URL=https://admin.example.com/admin

WEB_PORTAL_COOKIE_DOMAIN=
WEB_PORTAL_SECURE_COOKIE=false
WEB_PORTAL_ENFORCE_ORIGIN_CHECK=true
