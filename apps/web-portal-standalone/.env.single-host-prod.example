# Single-host production player portal profile
# Pair with root .env.single-host-prod.example on the same machine.

NODE_ENV=production
WEB_PORTAL_MODE=player
WEB_PORTAL_HOST=0.0.0.0
WEB_PORTAL_PORT=3300
WEB_PORTAL_BASE_URL=https://player.example.com
WEB_PORTAL_LEGACY_ADMIN_URL=https://admin.example.com/admin

WEB_PORTAL_COOKIE_DOMAIN=player.example.com
WEB_PORTAL_SECURE_COOKIE=true
WEB_PORTAL_ENFORCE_ORIGIN_CHECK=true
