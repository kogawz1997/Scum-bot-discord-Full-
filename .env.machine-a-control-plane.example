# Machine A: control plane
# Use on the host that owns:
# - Discord bot + admin web
# - worker runtime
# - standalone player portal
# - PostgreSQL / shop / wallet / audit state

NODE_ENV=production
DATABASE_PROVIDER=postgresql
PRISMA_SCHEMA_PROVIDER=postgresql
DATABASE_URL="postgresql://app:change-me@127.0.0.1:5432/scum_th_platform?schema=public"
PERSIST_REQUIRE_DB=true
PERSIST_LEGACY_SNAPSHOTS=false
ADMIN_SECURITY_EVENT_STORE_MODE=db
PLATFORM_AUTOMATION_STATE_STORE_MODE=db
PLATFORM_OPS_STATE_STORE_MODE=db
CONTROL_PLANE_REGISTRY_STORE_MODE=db
CONTROL_PLANE_REGISTRY_FILE_MIRROR_SLICES=none
TENANT_DB_ISOLATION_MODE=postgres-rls-strict
TENANT_DB_TOPOLOGY_MODE=schema-per-tenant

ADMIN_WEB_SESSION_COOKIE_PATH=/
ADMIN_WEB_SESSION_COOKIE_DOMAIN=admin.example.com
ADMIN_WEB_SECURE_COOKIE=true
ADMIN_WEB_ALLOWED_ORIGINS=https://admin.example.com
WEB_PORTAL_BASE_URL=https://portal.example.com
PLATFORM_PUBLIC_BASE_URL=https://portal.example.com
PLATFORM_BILLING_PROVIDER=stripe
PLATFORM_BILLING_WEBHOOK_SECRET=put_a_strong_billing_webhook_secret_here
PLATFORM_BILLING_STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
PLATFORM_BILLING_STRIPE_SECRET_KEY=sk_live_replace_me

DELIVERY_EXECUTION_MODE=agent
SCUM_CONSOLE_AGENT_BASE_URL=http://scum-node.example.internal:3213
SCUM_CONSOLE_AGENT_TOKEN=put_a_strong_agent_token_here

BOT_ENABLE_SCUM_WEBHOOK=true
BOT_ENABLE_ADMIN_WEB=true
BOT_ENABLE_RENTBIKE_SERVICE=false
BOT_ENABLE_DELIVERY_WORKER=false
BOT_HEALTH_PORT=3210

WORKER_ENABLE_RENTBIKE=true
WORKER_ENABLE_DELIVERY=true
WORKER_HEALTH_PORT=3211

SCUM_WATCHER_ENABLED=false
SCUM_WATCHER_HEALTH_PORT=0
