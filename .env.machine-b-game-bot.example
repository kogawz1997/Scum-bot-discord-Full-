# Machine B: game bot execution node
# Use on the Windows host that owns:
# - SCUM client
# - console-agent
# - watcher (if SCUM.log lives here)
#
# Keep business state on Machine A. This node executes commands and forwards
# watcher events back to Machine A.

NODE_ENV=production
DATABASE_PROVIDER=postgresql
PRISMA_SCHEMA_PROVIDER=postgresql
DATABASE_URL="postgresql://app:change-me@control-plane-db.example.internal:5432/scum_th_platform?schema=public"
PERSIST_REQUIRE_DB=true
PERSIST_LEGACY_SNAPSHOTS=false
TENANT_DB_ISOLATION_MODE=postgres-rls-strict
TENANT_DB_TOPOLOGY_MODE=schema-per-tenant

ADMIN_WEB_SESSION_COOKIE_PATH=/
ADMIN_WEB_SESSION_COOKIE_DOMAIN=admin.example.com
ADMIN_WEB_SECURE_COOKIE=true
ADMIN_WEB_ALLOWED_ORIGINS=https://admin.example.com

DELIVERY_EXECUTION_MODE=agent
SCUM_CONSOLE_AGENT_BASE_URL=http://127.0.0.1:3213
SCUM_CONSOLE_AGENT_HOST=0.0.0.0
SCUM_CONSOLE_AGENT_PORT=3213
SCUM_CONSOLE_AGENT_TOKEN=put_a_strong_agent_token_here
SCUM_CONSOLE_AGENT_BACKEND=exec

SCUM_WATCHER_ENABLED=true
SCUM_WATCHER_HEALTH_PORT=3212
SCUM_WEBHOOK_URL=https://control-plane.example.com/scum-event
SCUM_LOG_PATH=D:\\SCUMServer\\SCUM.log

BOT_ENABLE_SCUM_WEBHOOK=false
BOT_ENABLE_ADMIN_WEB=false
BOT_ENABLE_RENTBIKE_SERVICE=false
BOT_ENABLE_DELIVERY_WORKER=false
BOT_HEALTH_PORT=0

WORKER_ENABLE_RENTBIKE=false
WORKER_ENABLE_DELIVERY=false
WORKER_HEALTH_PORT=0
