[Unit]
Description=SCUM Platform Player Web Portal
After=network.target

[Service]
Type=simple
User=scum
WorkingDirectory=/opt/scum-platform
Environment=NODE_ENV=production
EnvironmentFile=/opt/scum-platform/.env
EnvironmentFile=/opt/scum-platform/apps/web-portal-standalone/.env
ExecStart=/usr/bin/node apps/web-portal-standalone/server.js
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
